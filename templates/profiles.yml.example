# dbt profiles.yml template
# Copie para ~/.dbt/profiles.yml e preencha os valores

default:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account
      project: seu-projeto-id
      dataset: seu_dataset_dev
      threads: 4
      timeout_seconds: 300
      keyfile: /path/to/service-account.json
      location: US

    prod:
      type: bigquery
      method: service-account
      project: seu-projeto-id
      dataset: seu_dataset_prod
      threads: 8
      timeout_seconds: 600
      keyfile: /path/to/service-account.json
      location: US

# Alternativa: PostgreSQL
postgres_local:
  target: dev
  outputs:
    dev:
      type: postgres
      host: localhost
      port: 5432
      user: seu_usuario
      password: sua_senha
      dbname: seu_banco
      schema: public
      threads: 4

# "A boa arquitetura e aquela que suporta as mudancas que a vida exige." -- Frederick Brooks
